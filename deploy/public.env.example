# Copy to deploy/public.env and chmod 600 before using launchd.
# Do not commit the real deploy/public.env file.

OWQ_ENV=production
OWQ_PUBLIC_BASE_URL=https://quant.ourworlds.app
OWQ_COOKIE_SECURE=1
OWQ_SECRET_FILE=data/app.secret
OWQ_APP_DB=data/app.sqlite
OWQ_APP_BACKUP_DIR=data/backups
OWQ_APP_BACKUP_KEEP=30
OWQ_APP_BACKUP_MAX_AGE_HOURS=48
OWQ_AUDIT_RETENTION_DAYS=400
OWQ_EMAIL_LOGIN_SESSION_RETENTION_DAYS=30
OWQ_OPERATIONAL_QUEUE_MAX_AGE_HOURS=72
OWQ_SERVER_ERROR_WINDOW_HOURS=24
OWQ_DISK_CHECK_PATH=data
OWQ_MIN_FREE_DISK_MB=1024
OWQ_SQLITE_MAX_WAL_MB=256
OWQ_DB_PATH=data/market.duckdb
OWQ_HOST=127.0.0.1
OWQ_PORT=8081
OWQ_RATE_LIMITS_DISABLED=0
OWQ_HEALTH_DETAIL_TOKEN=
OWQ_LEGAL_CONSENT_REQUIRED=1

# Keep this disabled for formal production. Set to 1 only for a short public beta
# before transactional email credentials are ready.
OWQ_EMAIL_DEV_AUTH=0
# Keep public pages from showing one-time test verification links.
OWQ_EMAIL_DEV_AUTH_SHOW_LINKS=0
OWQ_ADMIN_USER_IDS=
OWQ_ADMIN_EMAILS=

# Cloudflare Email Sending.
# Email login sending. Use either Cloudflare Email Service REST API or SMTP.
# Cloudflare Email Routing/forwarding handles inbound mail; verification links need Email Sending.
# Sending to arbitrary users requires a verified sending domain and a plan with outbound sending.
# OWQ_EMAIL_FROM must be one plain sender address; use OWQ_EMAIL_FROM_NAME for the display name.
OWQ_EMAIL_PROVIDER=cloudflare
OWQ_EMAIL_FROM=noreply@ourworlds.app
OWQ_EMAIL_FROM_NAME="OurWorlds Quant"
OWQ_EMAIL_TEST_MAX_AGE_HOURS=72
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# SMTP alternative.
# For Google/Gmail SMTP use smtp.gmail.com with TLS 587 or SSL 465 and a Google App Password.
# For Cloudflare SMTP use smtp.mx.cloudflare.net with SSL 465, user api_token, and an API token password.
OWQ_SMTP_HOST=
OWQ_SMTP_PORT=587
OWQ_SMTP_USER=
OWQ_SMTP_PASSWORD=
OWQ_SMTP_TLS=1
OWQ_SMTP_SSL=0

# Market sync and research reports.
OWQ_MARKET_SOURCE=tushare
OWQ_MARKET_LIMIT=500
OWQ_MARKET_MIN_REAL_CODES=300
OWQ_MARKET_MAX_STALENESS_DAYS=10
OWQ_MARKET_SYNC_MAX_AGE_HOURS=36
OWQ_MARKET_DATA_ADJUST=none
OWQ_MARKET_APP_ADJUST=none
OWQ_SYNC_DATA_FIRST=1
OWQ_SYNC_STOCKS=1
OWQ_SYNC_REPORTS=1
OWQ_SYNC_PRUNE_AUDIT=1
OWQ_SYNC_PRUNE_EMAIL_LOGIN=1
OWQ_SYNC_STRICT_READY=0
OWQ_START=20240101
OWQ_SLEEP=1.3
OWQ_REPORT_START=20230101
OWQ_REPORT_ADJUST=none
OWQ_REPORT_TOP=20
OWQ_PREDICTIONS_CSV=reports/predictions.csv
OWQ_PREDICTIONS_MIN_CODES=10
TUSHARE_TOKEN=
